{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git diff)",
      "Bash(git log:*)",
      "Bash(git log)",
      "Bash(git branch:*)",
      "Bash(git branch)",
      "Bash(git show:*)",
      "Bash(git worktree list:*)",
      "Bash(git worktree list)",
      "Bash(git worktree add:*)",
      "Bash(git worktree remove:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(pytest:*)",
      "Bash(pytest)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(bandit:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(npm test:*)",
      "Bash(npm test)",
      "Bash(npm run test:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "Bash(npx --no-install eslint:*)",
      "Bash(npx --no-install tsc:*)",
      "Bash(yarn test:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run test:*)",
      "Bash(eslint:*)",
      "Bash(tsc:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go build:*)",
      "Bash(gofmt:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo check:*)",
      "Bash(cargo fmt:*)",
      "Bash(rustfmt:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_write_guard.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_write_gate.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop_full_gate.py\""
          }
        ]
      }
    ]
  }
}
