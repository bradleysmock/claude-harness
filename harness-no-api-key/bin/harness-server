#!/usr/bin/env bash
# MCP server entry point. Creates the venv on first launch if it doesn't exist.
set -euo pipefail

PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV="$PLUGIN_DIR/.venv"

if [[ ! -f "$VENV/bin/python" ]]; then
    echo "harness: bootstrapping venv..." >&2
    python3 -m venv "$VENV"
    "$VENV/bin/pip" install --quiet --upgrade pip
    "$VENV/bin/pip" install --quiet "mcp>=1.0"
fi

exec "$VENV/bin/python" "$PLUGIN_DIR/server.py" "$@"
