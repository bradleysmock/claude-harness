# Runtime state — generated by init-pipeline.sh and update-state.sh
.claude/state/pipeline.json
.claude/state/pipeline.log
.claude/state/state.json
.claude/state/tasks/

# Local permission overrides
.claude/settings.local.json

# Worktrees
.claude/worktrees/

# Analysis output — generated artefacts at project root (not the command template)
/CRITIQUE.md
/pipeline/

# Python bytecode from hook scripts
__pycache__/
*.pyc
.DS_Store

# MCP plugin venv — created by harness-full-mcp/setup.sh
harness-full-mcp/.venv/

# harness-full build artifacts
harness-full/*.egg-info/
