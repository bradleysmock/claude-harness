{
  "env": {
    "PIPELINE_STATE_FILE": ".claude/state/pipeline.json",
    "PIPELINE_LOG_FILE": ".claude/state/pipeline.log",
    "COVERAGE_LINE_THRESHOLD": "80",
    "COVERAGE_BRANCH_THRESHOLD": "70",
    "COMPLEXITY_FLAG_ABOVE": "10",
    "COMPLEXITY_BLOCK_ABOVE": "20",
    "SAST_BLOCK_SEVERITY": "HIGH",
    "MAX_AUTO_REMEDIATION_ATTEMPTS": "2",
    "MAX_CONTEXT_TOKENS": "4000",
    "PERFORMANCE_REGRESSION_THRESHOLD_PCT": "15",
    "APPROVED_LANGUAGES": "python,typescript,javascript,go,rust,java",
    "HIGH_RISK_PATTERNS": "authentication,authorisation,authorization,payment,cryptography,crypto,jwt,oauth,rbac",
    "PIPELINE_VERSION": "1.0.0"
  },
  "permissions": {
    "allow": [
      "Bash(python3*)",
      "Bash(python*)",
      "Bash(node*)",
      "Bash(npm*)",
      "Bash(npx*)",
      "Bash(pip*)",
      "Bash(pip3*)",
      "Bash(git*)",
      "Bash(find*)",
      "Bash(cat*)",
      "Bash(echo*)",
      "Bash(mkdir*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(chmod*)",
      "Bash(ls*)",
      "Bash(grep*)",
      "Bash(sed*)",
      "Bash(awk*)",
      "Bash(jq*)",
      "Bash(wc*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(sort*)",
      "Bash(uniq*)",
      "Bash(bash .claude/hooks/*)",
      "Bash(sh .claude/hooks/*)",
      "Bash(semgrep*)",
      "Bash(gitleaks*)",
      "Bash(ruff*)",
      "Bash(mypy*)",
      "Bash(pytest*)",
      "Bash(coverage*)",
      "Bash(eslint*)",
      "Bash(tsc*)",
      "Bash(radon*)",
      "Bash(pip-audit*)",
      "Bash(npm audit*)",
      "Bash(licensecheck*)"
    ],
    "deny": [
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)",
      "Bash(rm -rf /*)",
      "Bash(sudo rm*)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-write.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/on-stop.sh"
          }
        ]
      }
    ]
  }
}
