FROM node:20-slim

# Install gate tools globally
RUN npm install -g --no-audit \
    typescript@5 \
    eslint@8 \
    @typescript-eslint/parser@6 \
    @typescript-eslint/eslint-plugin@6 \
    jest@29 \
    ts-jest@29 \
    @types/jest@29

# Create non-root user for execution
RUN useradd -m -u 1000 harness
USER harness
WORKDIR /work
