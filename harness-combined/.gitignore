# Python bytecode caches generated when the MCP server imports modules
__pycache__/
*.pyc
*.pyo

# Tool caches
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Local venvs
.venv/

# Sandbox temp dirs for `/build --dry-run` (dry_run.py) — cleaned per run
.harness/dry-run-tmp/

# Transient per-language gate execution logs written during gate runs / tests
.harness/gate-logs/

# Transient craft-polish reports (.harness/craft/<ticket>.json) — ephemeral, like results/
.harness/craft/

# macOS
.DS_Store

# dep-audit gate writes its FR-4 report to the project root; keep the transient
# root copy out of git (the canonical report lives under .tickets/XXXX-<slug>/).
/gate-findings.md
